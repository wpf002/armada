# ---------------------------------------------------------------------------
# Armada environment variables. Copy to `.env` and fill in real values.
# `.env` is gitignored. Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Database (Postgres) ---
# Local dev uses the docker-compose Postgres below.
DATABASE_URL="postgresql://armada:armada@localhost:5432/armada?schema=public"

# --- Auth (Better Auth) ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# --- API (Fastify) ---
API_PORT="4000"
API_HOST="0.0.0.0"
# Comma-separated list of allowed web origins for CORS.
WEB_ORIGIN="http://localhost:3000"

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Fillout integration ---
FILLOUT_API_KEY=""
FILLOUT_FORM_ID="dHqhm2ovxQus"
# Shared secret used to verify inbound Fillout webhooks.
FILLOUT_WEBHOOK_SECRET="change-me"

# --- Worker (nightly reconcile) ---
# Cron expression for the Fillout reconcile job (default: 3am daily).
RECONCILE_CRON="0 3 * * *"
# Weekly metadata-drift check (default: Mondays 4am).
DRIFT_CRON="0 4 * * 1"
# The worker calls the API's internal endpoints with the shared secret above.
API_INTERNAL_URL="http://localhost:4000"
